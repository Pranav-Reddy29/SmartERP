generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @default(uuid())

  name String

  email String @unique

  password String

  role String @default("USER")

  companies Company[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("users")
}

model Company {
  id String @id @default(uuid())

  companyName String

  gstNumber String?

  state String?

  address String?

  phone String?

  financialYear String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  groups LedgerGroup[]

  ledgers Ledger[]

  categories Category[]

  units Unit[]

  products Product[]

  @@map("companies")
}

model LedgerGroup {
  id String @id @default(uuid())

  name String

  nature String

  description String?

  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  parentId String?

  parent LedgerGroup? @relation("GroupHierarchy", fields: [parentId], references: [id])

  children LedgerGroup[] @relation("GroupHierarchy")

  ledgers Ledger[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("ledger_groups")
}

model Ledger {
  id String @id @default(uuid())

  ledgerName String

  ledgerType String

  openingBalance Float @default(0)

  balanceType String

  gstNumber String?

  phone String?

  email String?

  address String?

  state String?

  isActive Boolean @default(true)

  companyId String

  groupId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  group LedgerGroup @relation(fields: [groupId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("ledgers")
}

model Category {
  id String @id @default(uuid())

  name String

  description String?

  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@map("categories")
}

model Unit {
  id String @id @default(uuid())

  name String

  shortName String

  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@map("units")
}

model Product {
  id String @id @default(uuid())

  name String

  sku String?

  hsnCode String?

  gstRate Float @default(18)

  openingStock Float @default(0)

  purchasePrice Float @default(0)

  sellingPrice Float @default(0)

  minimumStock Float @default(0)

  isActive Boolean @default(true)

  categoryId String

  category Category @relation(fields: [categoryId], references: [id])

  unitId String

  unit Unit @relation(fields: [unitId], references: [id])

  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@map("products")
}
